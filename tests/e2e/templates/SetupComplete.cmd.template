@echo off
setlocal

rem ============================================================================
rem  SetupComplete.cmd — runs as LocalSystem the first time Windows reaches the
rem  logon screen, BEFORE any interactive logon. Generated by Bootstrap-VM.ps1
rem  with {USERNAME} and {PASSWORD} substituted from the template.
rem
rem  Why we create+reset the user here instead of relying solely on the
rem  autounattend.xml <LocalAccount> block:
rem    * Windows 11 build 26200 (25H2) removed BypassNRO and tightened OOBE.
rem      The <LocalAccount>/<AutoLogon> XML can be silently ignored or applied
rem      with a different password than we specified, leaving the host stuck
rem      at Wait-VmReady with "Guest rejected the configured credentials".
rem    * Running `net user … /add` here is idempotent in our favour: if the
rem      account already exists we just reset the password; if not, we create
rem      it. Either way the credentials in .vm-creds.json are guaranteed to
rem      match what PowerShell Direct will see.
rem ============================================================================

if not exist C:\Setup md C:\Setup

echo [%date% %time%] SetupComplete started > C:\Setup\SetupComplete.log

rem ---- 1) Make sure the test user exists with the password we generated. -----
rem      `net user … /add` fails if the account already exists; the follow-up
rem      `net user … <password>` then resets the password unconditionally.
net user {USERNAME} "{PASSWORD}" /add /active:yes /passwordchg:no /fullname:"{USERNAME}" /comment:"VhdxManager E2E test user" >> C:\Setup\SetupComplete.log 2>&1
net user {USERNAME} "{PASSWORD}" >> C:\Setup\SetupComplete.log 2>&1
net user {USERNAME} /active:yes >> C:\Setup\SetupComplete.log 2>&1
net user {USERNAME} /expires:never >> C:\Setup\SetupComplete.log 2>&1
net user {USERNAME} /passwordreq:yes >> C:\Setup\SetupComplete.log 2>&1

rem ---- 2) Promote to Administrators (idempotent — error 1378 if already in). -
net localgroup Administrators {USERNAME} /add >> C:\Setup\SetupComplete.log 2>&1

rem ---- 3) Disable host-wide password aging so the test password never expires.
net accounts /maxpwage:unlimited >> C:\Setup\SetupComplete.log 2>&1

rem ---- 4) Belt-and-braces: clear the "password never expires" flag on the user
rem        record itself. Some Win11 builds set this from policy and override
rem        `net accounts`. WMIC is deprecated but still present on 25H2.
wmic useraccount where "Name='{USERNAME}'" set PasswordExpires=FALSE >> C:\Setup\SetupComplete.log 2>&1

rem ---- 5) Run the configuration script as LocalSystem. ----------------------
powershell.exe -NoProfile -ExecutionPolicy Bypass -File C:\Setup\FirstLogon.ps1 >> C:\Setup\SetupComplete.log 2>&1
set EXITCODE=%ERRORLEVEL%
echo [%date% %time%] SetupComplete finished with exit code %EXITCODE% >> C:\Setup\SetupComplete.log

exit /b 0
