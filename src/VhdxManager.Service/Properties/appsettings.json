{
	"VhdxManager": {
		"AllowedParentPaths": [ "*" ],
		"AllowedMountBasePaths": [ "*" ],
		"AllowedChildBasePaths": [ "*" ],
		"AllowedConvertSourcePaths": [ "*" ],
		"StatePath": "%ProgramData%\\VhdxManager\\state.json",
		"PipeName": "VhdxManagerService",
		"Defaults": {
			"AddDefenderExclusion": null
		}
	},
	"Serilog": {
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft.AspNetCore": "Warning",
				"Grpc": "Warning"
			}
		},
		"WriteTo": [
			{
				"Name": "File",
				"Args": {
					"path": "%ProgramData%/VhdxManager/logs/service-.log",
					"rollingInterval": "Day",
					"retainedFileCountLimit": 30,
					"outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
				}
			},
			{
				"Name": "EventLog",
				"Args": {
					"source": "VhdxManager",
					"restrictedToMinimumLevel": "Warning"
				}
			}
		]
	}
}
