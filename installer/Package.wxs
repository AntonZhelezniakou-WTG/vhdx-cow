<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

	<Package
		Name="VHDX Manager"
		Manufacturer="WiseTechGlobal"
		Version="$(var.Version)"
		UpgradeCode="B7E4F9A2-3C1D-4E8F-A6B5-9D2C7E1F0A3B"
		Scope="perMachine"
		Compressed="yes">

		<SummaryInformation
			Description="VHDX Manager for Windows" />

		<!--
			Schedule="afterInstallExecute": new product installs FIRST, then
			RemoveExistingProducts removes the old. This is the WiX-recommended
			schedule for installers that use `<Files Include="**">` harvesting:
			the harvester emits deterministic ComponentIDs derived from file
			paths, so the same ComponentID appears in both old and new MSI for
			every file at the same relative path. With "afterInstallInitialize"
			(old-then-new) Windows Installer sees the shared components as
			"Unchanged" between the two installs, skips InstallFiles for them
			during the new install, then deletes them as part of removing the
			old product — leaving the install with no `vhdx.exe` or
			`VhdxManager.Service.exe`. "afterInstallExecute" installs the new
			version first; the subsequent RemoveExistingProducts sees the shared
			components as still referenced (by the new install) and leaves them
			in place. Covered by tests/VhdxManager.E2E.Tests/Installer/Upgrade_Tests.cs.
		-->
		<MajorUpgrade
			DowngradeErrorMessage="A newer version of [ProductName] is already installed."
			Schedule="afterInstallExecute" />

		<!--
			Force every file to be re-installed during a MajorUpgrade, regardless
			of the version stamp on the on-disk file. Without this, Windows
			Installer's default REINSTALLMODE ("omus") compares FileVersion of
			the candidate file against the installed one and keeps whichever is
			newer. A prior release that shipped without an explicit
			/p:Version=X.Y.Z on `dotnet publish` would have FileVersion=1.0.0.0
			(SDK default) on its binaries; any future release with a "real"
			lower-numbered version (e.g. 0.2.1) would lose the version
			comparison and the upgrade would silently keep the old binaries
			even though the package is registered as the new version.
			"amus" — Always overwrite, rewrite Machine reg, rewrite User reg,
			recreate Shortcuts — sidesteps this comparison entirely.
		-->
		<Property Id="REINSTALLMODE" Value="amus" />

		<MediaTemplate EmbedCab="yes" />

		<!-- Directory structure -->
		<StandardDirectory Id="ProgramFiles6432Folder">
			<Directory Id="INSTALLFOLDER" Name="VhdxManager">
				<Directory Id="ServiceFolder" Name="Service" />
				<Directory Id="CliFolder" Name="Cli" />
			</Directory>
		</StandardDirectory>

		<StandardDirectory Id="CommonAppDataFolder">
			<Directory Id="ProgramDataVhdxManager" Name="VhdxManager">
				<Directory Id="ProgramDataLogs" Name="logs" />
			</Directory>
		</StandardDirectory>

		<!-- Features -->
		<Feature Id="ServiceFeature"
			Title="VhdxManager Service"
			Description="Windows Service for privileged VHDX operations"
			Level="1"
			AllowAbsent="no">
			<ComponentGroupRef Id="ServiceComponents" />
			<ComponentGroupRef Id="ConfigComponents" />
		</Feature>

		<Feature Id="CliFeature"
			Title="vhdx CLI"
			Description="Command-line tool (added to PATH)"
			Level="1"
			AllowAbsent="yes">
			<ComponentGroupRef Id="CliComponents" />
			<ComponentRef Id="CliPathComponent" />
		</Feature>

		<!--
			Built-in Welcome+License → Progress → Finish UI from the WiX UI extension.
			Replaces the previous silent install flow. The Finish step shows
			"Setup completed successfully" plus the optional text below.

			WixUI_ErrorProgressText is added explicitly: WixUI_Minimal does NOT pull it
			in by default in WiX 5, which leaves the progress dialog showing literal
			"File: [1], Directory: [9], Size: [6]" placeholders instead of formatted
			values during file copy.
		-->
		<!-- WixUI_VhdxManager is our copy of WixUI_Minimal that uses a patched
		     WelcomeEulaDlg with Sunken="yes" on the LicenseAcceptedCheckBox
		     (see installer/CustomDialogs.wxs). _X64 is the per-arch variant
		     that wires the Print button to WixUIPrintEula_X64. -->
		<UIRef Id="WixUI_VhdxManager_X64" />
		<UIRef Id="WixUI_ErrorProgressText" />
		<WixVariable Id="WixUILicenseRtf" Value="$(var.ProjectDir)license.rtf" />
		<Property Id="WIXUI_EXITDIALOGOPTIONALTEXT"
			Value="The VhdxManager service is registered and the 'vhdx' CLI has been added to PATH. Open a new console and run 'vhdx ping' to verify." />

	</Package>

</Wix>
