<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

	<Fragment>
		<ComponentGroup Id="ConfigComponents">

			<!-- Empty logs directory in ProgramData — preserved on uninstall -->
			<Component Id="LogsDirectoryComponent"
				Directory="ProgramDataLogs"
				Permanent="yes"
				Guid="D3E5A7C9-1F2B-4D6E-8A0C-3B5D7F9E1A2C"
				KeyPath="yes">
				<CreateFolder />
			</Component>

			<!--
				Installation diagnostics script.
				Permanent="yes" so it survives a rollback caused by a failing install
				step (e.g. service start failure). The Custom Action that runs this
				script is scheduled in InstallUISequence after ExecuteAction; by then
				the file is on disk regardless of whether the install succeeded.
			-->
			<Component Id="InstallDiagnosticsComponent"
				Directory="ProgramDataVhdxCow"
				Permanent="yes"
				Guid="E5F7B9CB-2A3D-4F6E-9C0D-4F6E8A0B2C3D">
				<File Id="InstallDiagnosticsPs1"
					Source="$(var.ProjectDir)InstallDiagnostics.ps1"
					KeyPath="yes"
					Name="InstallDiagnostics.ps1" />
			</Component>

		</ComponentGroup>
	</Fragment>

	<Fragment>
		<!--
			Immediate Custom Action — runs in the active user session via msiexec UI
			thread, so WinForms dialogs work. Schedule it in InstallUISequence so:
			  * It only runs during interactive installs (silent /qn skips UISequence).
			  * It runs AFTER ExecuteAction, i.e. after files are installed and the
			    service start has been attempted, giving us the full picture.
			Return="ignore" — diagnostic UI must never break the installer.
		-->
		<CustomAction Id="ShowInstallDiagnostics"
			Directory="ProgramDataVhdxCow"
			ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "[CommonAppDataFolder]VhdxCow\InstallDiagnostics.ps1"'
			Execute="immediate"
			Return="ignore" />

		<InstallUISequence>
			<Custom Action="ShowInstallDiagnostics" After="ExecuteAction" Condition="NOT REMOVE" />
		</InstallUISequence>
	</Fragment>

</Wix>
