<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

	<Fragment>
		<ComponentGroup Id="ServiceComponents" Directory="ServiceFolder">

			<!-- Service executable: explicit component for ServiceInstall metadata -->
			<Component Id="ServiceExeComponent" Guid="*">
				<!--
					Name="..." is required: WiX 4/5 computes the installed file's name
					from the literal Source string before bindpath resolution, so without
					Name= the file lands as "!(bindpath.ServicePublish)VhdxCow.Service.exe".
				-->
				<File Id="ServiceExe"
					Source="!(bindpath.ServicePublish)VhdxCow.Service.exe"
					Name="VhdxCow.Service.exe"
					KeyPath="yes" />

				<ServiceInstall
					Id="VhdxCowServiceInstall"
					Name="VhdxCowService"
					DisplayName="VHDX Copy-on-Write Service"
					Description="Manages VHDX differencing disks for Copy-on-Write workflows."
					Type="ownProcess"
					Start="auto"
					Account="LocalSystem"
					ErrorControl="normal"
					Vital="yes" />

				<!--
					Wait="no": MSI fires the start request and moves on without blocking. If
					the service crashes during startup (e.g. unhandled exception), the user
					still sees our own crash-report dialog (spawned by FatalDiagnostics into
					the active session), but MSI no longer surfaces its own "service failed
					to start [Retry][Cancel]" loop, which previously triggered repeated
					crashes and duplicated dialogs.
				-->
				<ServiceControl
					Id="VhdxCowServiceControl"
					Name="VhdxCowService"
					Start="install"
					Stop="both"
					Remove="uninstall"
					Wait="no" />

				<!--
					Failure actions deliberately set to "none": when the service fails on
					first start we want the user to see ONE crash-report dialog and decide
					what to do, not have SCM silently restart the process and duplicate the
					dialog every 60 seconds.
				-->
				<util:ServiceConfig
					ServiceName="VhdxCowService"
					FirstFailureActionType="none"
					SecondFailureActionType="none"
					ThirdFailureActionType="none"
					ResetPeriodInDays="1" />

				<!-- Event Log source registration -->
				<util:EventSource
					Name="VhdxCow"
					Log="Application"
					EventMessageFile="[#ServiceExe]" />
			</Component>

			<!-- All other service files (DLLs, deps.json, runtimeconfig.json, appsettings.json,
			     CrashReportDialog.ps1, etc.) -->
			<Files Include="!(bindpath.ServicePublish)**">
				<Exclude Files="!(bindpath.ServicePublish)VhdxCow.Service.exe" />
				<Exclude Files="!(bindpath.ServicePublish)**\*.pdb" />
			</Files>

		</ComponentGroup>
	</Fragment>

</Wix>
